# Public site URL used for emails, Stripe redirects, calendar links, and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin login. In local development, the app falls back to ikada-admin-local if unset.
ADMIN_PASSWORD=change-this-password
SESSION_SECRET=replace-with-a-long-random-string

# Local file adapter is the default when Supabase is not configured.
# Set these to use Supabase/Postgres in production.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe Checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend email.
RESEND_API_KEY=
EMAIL_FROM=IKADA <ikada.amami@gmail.com>
HOST_EMAIL=ikada.amami@gmail.com
